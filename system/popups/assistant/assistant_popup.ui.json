{
  "name": "assistant_popup",
  "root": {
    "type": "container",
    "id": "root",
    "geometry": { "x": 0, "y": 0, "w": "100%", "h": "100%" },
    "padding": [12, 12, 100, 10],
    "opa": 178,
    "layout": {
      "type": "vbox",
      "spacing": 0,
      "main_align": "end",
      "cross_align": "center"
    },
    "children": [
      {
        "type": "container",
        "id": "frame",
        "size": { "w": "100%", "h": "content" },
        "max_size": { "h": "100%" },
        "height_policy": "content_max_parent",
        "padding": [2, 2, 2, 2],
        "radius": 10,
        "border_width": 2,
        "opa": 255,
        "clip_corner": true,
        "layout": {
          "type": "vbox",
          "spacing": 0,
          "main_align": "start",
          "cross_align": "start"
        },
        "children": [
          {
            "type": "container",
            "id": "scroll",
            "size": { "w": "100%", "h": "content" },
            "max_size": { "h": "100%" },
            "height_policy": "content_max_parent",
            "padding": [16, 16, 16, 16],
            "border_width": 0,
            "opa": 0,
            "layout": {
              "type": "vbox",
              "spacing": 10,
              "main_align": "start",
              "cross_align": "start"
            },
            "scroll": {
              "enabled": true,
              "dir": "ver",
              "scrollbar": "auto"
            },
            "children": [
              {
                "type": "label",
                "id": "question_label",
                "size": { "w": "100%", "h": "content" },
                "text": " ",
                "align": "left",
                "overflow": "wrap"
              },
              {
                "type": "label",
                "id": "answer_label",
                "size": { "w": "100%", "h": "content" },
                "text": " ",
                "align": "left",
                "overflow": "wrap"
              }
            ]
          }
        ]
      }
    ]
  }
}
